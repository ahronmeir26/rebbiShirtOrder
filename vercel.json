{
  "version": 2,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/api/login"
    },
    {
      "source": "/logout",
      "destination": "/api/logout"
    },
    {
      "source": "/rso/login",
      "destination": "/api/login"
    },
    {
      "source": "/rso/logout",
      "destination": "/api/logout"
    },
    {
      "source": "/testivr",
      "destination": "/testivr/index.html"
    },
    {
      "source": "/transfers",
      "destination": "/transfers/index.html"
    },
    {
      "source": "/rso",
      "destination": "/"
    },
    {
      "source": "/rso/testivr",
      "destination": "/testivr/index.html"
    },
    {
      "source": "/rso/transfers",
      "destination": "/transfers/index.html"
    },
    {
      "source": "/rso/:path*",
      "destination": "/:path*"
    }
  ]
}
